# ticket_processing
# 工单处理工作流

workflow ticket_processing {
  agent classify {
    prompt: "分类工单: {input}"
    input_schema: {'ticket': 'string'}
    output_schema: {'category': 'string'}
  }

  agent priority {
    prompt: "判断优先级: {input}"
    input_schema: {'ticket': 'string'}
    output_schema: {'priority': 'string'}
  }

  agent route {
    type: "condition"
  }

  agent human {
    type: "manual"
    prompt: "人工处理工单"
  }

  agent bot {
    prompt: "自动回复: {input}"
    input_schema: {'ticket': 'string', 'category': 'string'}
    output_schema: {'response': 'string'}
  }

  # 执行流
  classify -> route
  priority -> route
  (human, bot)
}